# ---- Backend mode ----
# "mock"  -> in-process deterministic fake LLM, no GPU needed (used for tests/CI/dev)
# "vllm"  -> real vLLM server with LMCache connector (production, requires GPU host)
LLM_BACKEND_MODE=mock

# ---- vLLM / LMCache production endpoint ----
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct
VLLM_API_KEY=not-needed

# ---- KV cache memory budget (GPU host) ----
KV_CACHE_BUDGET_GB=8
LMCACHE_CPU_OFFLOAD_GB=40
LMCACHE_DISK_PATH=/mnt/lmcache/store
LMCACHE_CHUNK_SIZE=256

# ---- Concurrency ----
MAX_CONCURRENT_SESSIONS=100
SESSION_TTL_SECONDS=1800
MAX_HISTORY_TURNS=8

# ---- Vector DB ----
CHROMA_PERSIST_DIR=./data/chroma
KB_TOP_K=4

# ---- Quality gate ----
QUALITY_SCORE_THRESHOLD=0.75
MAX_QUALITY_RETRIES=2

# ---- Logging ----
LOG_LEVEL=INFO
